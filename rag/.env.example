# Copy this file to rag/.env and fill in your values.
# rag/.env is gitignored -- do not commit it.

# Hugging Face token (used once to download the embedding model).
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Run the embedder fully offline after the model is cached locally.
# Set to 1 after the first successful model download.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# Local LLM endpoint (OpenAI-compatible chat completions).
RAG_LLM_URL=http://localhost:8080/v1/chat/completions
RAG_LLM_MODEL=local-model

# RAG server bind address.
RAG_HOST=127.0.0.1
RAG_PORT=8765
